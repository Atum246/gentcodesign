# GentCoDesign Environment Variables
# Copy to .env and fill in your keys

# Default model provider (anthropic|openai|gemini|deepseek|openrouter|ollama)
GENT_DEFAULT_MODEL=anthropic

# API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Custom OpenAI-compatible endpoint
CUSTOM_BASE_URL=
CUSTOM_API_KEY=

# Server
GENT_PORT=3700
GENT_HOST=0.0.0.0

# Output
GENT_JSON=false
GENT_QUIET=false
